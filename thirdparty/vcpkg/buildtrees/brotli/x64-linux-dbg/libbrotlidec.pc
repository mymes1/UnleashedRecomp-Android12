prefix=/home/runner/workspace/thirdparty/vcpkg/packages/brotli_x64-linux/debug
exec_prefix=/home/runner/workspace/thirdparty/vcpkg/packages/brotli_x64-linux/debug
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libbrotlidec
URL: https://github.com/google/brotli
Description: Brotli decoder library
Version: 1.1.0
Libs: -L${libdir} -lbrotlidec
Requires.private: libbrotlicommon >= 1.1.0
Cflags: -I${includedir}
